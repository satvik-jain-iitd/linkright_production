# PostHog Analytics (free tier: 1M events/mo)
# Get your key at https://app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Supabase Auth + DB (free tier: 50K MAU, 500MB)
# Get your keys at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Razorpay (no monthly fee, 2% per transaction)
# Get your keys at https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Langfuse (LLM observability) — optional, traces disabled if not set
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Jina AI embeddings — for semantic JD matching (optional, degrades gracefully)
# Get a free key at https://jina.ai/
JINA_API_KEY=

# Platform Groq key — used when no user API key is available (platform-managed)
# Get a free key at https://console.groq.com
PLATFORM_GROQ_API_KEY=

# Supabase service role — required for oracle routes (bypasses RLS)
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Custom GPT ↔ Oracle integration (LifeOS career coaching)
# CUSTOM_GPT_SECRET: shared bearer token between ChatGPT GPT Actions and this server
#   Set in Vercel AND paste the same value into ChatGPT GPT builder → Actions → Auth → Bearer
CUSTOM_GPT_SECRET=
# ORACLE_BACKEND_URL: URL of the Oracle FastAPI backend
#   e.g. https://oracle-backend.onrender.com
ORACLE_BACKEND_URL=
# ORACLE_BACKEND_SECRET: bearer token for Oracle backend auth
ORACLE_BACKEND_SECRET=

# SMA_DIARY_INGEST_URL: webhook URL for SMA v2 diary pipeline (optional)
#   was hardcoded to http://10.0.0.253:5678/webhook/sma-diary-ingest
SMA_DIARY_INGEST_URL=
